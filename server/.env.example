PORT=5000
MONGODB_URI=mongodb://localhost:27017/ecommerce-nepal

CLIENT_URL=http://localhost:5173

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Leave blank to use the dev-mode console logger instead of real SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@ecommerce-nepal.local

# Leave blank to disable Google OAuth until you have real credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Khalti ePayment v2 — sandbox keys from https://test-admin.khalti.com (Settings > Keys)
KHALTI_SECRET_KEY=
KHALTI_BASE_URL=https://dev.khalti.com/api/v2

# eSewa ePay v2 — values below are eSewa's published UAT/sandbox constants (same for all
# merchants in test mode); replace with your real merchant product code + secret in production
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q(
ESEWA_FORM_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_URL=https://rc.esewa.com.np/api/epay/transaction/status/

# Nepal Can Move (NCM) logistics — leave NCM_API_TOKEN blank to disable this carrier.
# NCM_PICKUP_BRANCH is your own vendor warehouse branch (the "fbranch" NCM ships from).
NCM_API_TOKEN=
NCM_BASE_URL=https://demo.nepalcanmove.com/api
NCM_PICKUP_BRANCH=TINKUNE
