PORT=5000
MONGODB_URI=mongodb://localhost:27017/ecommerce-nepal

CLIENT_URL=http://localhost:5173

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Leave blank to use the dev-mode console logger instead of real SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@ecommerce-nepal.local

# Leave blank to disable Google OAuth until you have real credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
